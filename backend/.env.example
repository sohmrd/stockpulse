# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# Comma-separated list of allowed CORS origins (JSON array string)
CORS_ORIGINS=["http://localhost:3000"]
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL (used by SQLAlchemy at runtime)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stockpulse
# Sync URL (used by Alembic for migrations)
DATABASE_URL_SYNC=postgresql://user:pass@localhost:5432/stockpulse

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7
GOOGLE_CLIENT_ID=<oauth-client-id>
GOOGLE_CLIENT_SECRET=<oauth-client-secret>

# ── Market Data ───────────────────────────────────────────────────────────────
MARKET_DATA_API_KEY=<alpha-vantage-or-polygon-key>
# Supported values: alpha_vantage | polygon | finnhub
MARKET_DATA_PROVIDER=alpha_vantage

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-20250514
CLAUDE_MODEL_LIGHTWEIGHT=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS_TREND=2048
CLAUDE_MAX_TOKENS_SUGGESTION=4096
# Kill switch — set to false to disable all Claude API calls without redeployment
CLAUDE_ENABLED=true

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=<sentry-dsn>
